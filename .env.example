# --- App Config ---
PORT=3000
WEBHOOK_SECRET=super_secret_signing_key
LOG_LEVEL=info

# --- Database (MongoDB Atlas compatible) ---
MONGODB_URI=mongodb://127.0.0.1:27017/hookflow

# --- Queue (Upstash Redis compatible) ---
# For Upstash, use: redis://:PASSWORD@HOST:PORT
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_TLS=true (Set to true for Upstash)
